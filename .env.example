# Clinical Alpha Configuration
# Copy to .env and fill in your keys

# Polygon.io API key (optional - falls back to yfinance)
POLYGON_API_KEY=

# Data directories (defaults to ./data)
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
SAMPLE_DATA_DIR=data/samples
REPORT_DIR=reports
TABLE_DIR=reports/tables
FIGURE_DIR=reports/figures

# Logging level
LOG_LEVEL=INFO

# Max results from API fetches
MAX_TRIAL_FETCH=5000
MAX_FDA_FETCH=1000

# Overlapping event window in days
EVENT_LOOKBACK_DAYS=90
