# Clinical Alpha Configuration
# Copy to .env and fill in your keys

# ── API Keys ──────────────────────────────────────────────────────
POLYGON_API_KEY=

# ── Data Directories ──────────────────────────────────────────────
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
SAMPLE_DATA_DIR=data/samples
REPORT_DIR=reports
TABLE_DIR=reports/tables
FIGURE_DIR=reports/figures

# ── Fetch Limits ──────────────────────────────────────────────────
MAX_TRIAL_FETCH=5000
MAX_FDA_FETCH=1000

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=

# ── Event Processing ──────────────────────────────────────────
EVENT_LOOKBACK_DAYS=90

# ── Abnormal Return Estimation ────────────────────────────────
ESTIMATION_WINDOW=252
EVENT_WINDOW_BEFORE=10
EVENT_WINDOW_AFTER=20

# ── Factor Model ──────────────────────────────────────────────
FACTOR_MODELS=spy_adjusted,xlv_adjusted,xbi_adjusted,market_model,ff3

# ── Backtest ──────────────────────────────────────────────────
BACKTEST_TOP_K=5
BACKTEST_HOLDING_PERIODS=5,10,21,63
BACKTEST_TRANSACTION_COST_MODEL=linear
BACKTEST_BASE_TC_BPS=10.0
BACKTEST_SLIPPAGE_BPS=5.0
BACKTEST_WEIGHTING=equal
BACKTEST_VOL_TARGET=0.15
BACKTEST_MAX_LEVERAGE=1.0
BACKTEST_MAX_TURNOVER=0.50
BACKTEST_SECTOR_NEUTRAL=false
BACKTEST_LONG_SHORT=false
BACKTEST_SHORT_REBATE_RATE=0.003
BACKTEST_SHORT_FEE_BPS=35.0

# ── Robustness ────────────────────────────────────────────────
DEFAULT_CONFIDENCE_THRESHOLDS=0.6,0.7,0.8,0.9,0.95
DEFAULT_OVERLAP_DAYS=30

# ── Statistical Tests ─────────────────────────────────────────
BOOTSTRAP_N_ITERATIONS=10000
PERMUTATION_N_ITERATIONS=10000
ALPHA_LEVEL=0.05

# ── Risk Model ────────────────────────────────────────────────
RISK_LOOKBACK=252
RISK_SHRINKAGE_LAMBDA=0.5
RISK_N_FACTORS=5

# ── Data Quality ──────────────────────────────────────────────
MIN_OBSERVATIONS_PCT=0.80
MAX_RETURN_ZSCORE=6.0
MIN_PRICE=1.0
MAX_MISSING_CONSECUTIVE_DAYS=10

# ── Signal Analysis ───────────────────────────────────────────
SIGNAL_MIN_OBS=10
SIGNAL_N_QUANTILES=5
SIGNAL_MAX_LAG=63
SIGNAL_METHOD=pearson

# ── FDR Bootstrap ─────────────────────────────────────────────
N_BOOTSTRAP_FDR=1000

# ── Structural Breaks ─────────────────────────────────────────
STRUCTURAL_BREAK_MIN_SEGMENT=20

# ── Bayesian Priors ───────────────────────────────────────────
BAYES_PRIOR_SCALE=0.5

# ── Black-Litterman ───────────────────────────────────────────
BLACK_LITTERMAN_TAU=0.05
BLACK_LITTERMAN_RISK_AVERSION=2.5
